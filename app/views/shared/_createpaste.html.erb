<div
    data-controller="markdown-preview" 
    data-markdown-preview-url-value="<%= preview_pastes_path %>" 
    data-action="input->markdown-preview#queue change->markdown-preview#queue">
    <div class="p-4">
    <%= form_with model: @paste, class: "space-y-3" do |f| %>
        <% if @paste.errors.any? %>
            <div class="border border-red-300 bg-red-50 p-3 text-sm">
                <div class="font-bold mb-1">Error</div>
                <ul class="list-disc pl-5">
                    <% @paste.errors.full_messages.each do |msg| %>
                        <li><%= msg %></li>
                    <% end %>
                </ul>
            </div>
        <% end %>

        <div>
            <%= f.label :title, "Title", class: "block text-sm font-semibold" %>
            <%= f.text_field :title, class: "mt-1 w-full border border-[var(--border)] px-3 py-2" %>
        </div>

        <div>
            <%= f.label :body, "Paste", class: "block text-sm font-semibold" %>
            <%= render "shared/paste_editor", f: f, field: :body, rows: 14 %>
        </div>

        <div>
            <%= f.label :render_type, class: "block text-sm font-semibold" do %>
                <%= f.check_box :render_type, { class: "mr-2" }, "markdown", "plain" %>
                Use markdown
            <% end %>
        </div>

        <div>
            <%= f.label :tags, "Tags (comma separated)", class: "block text-sm font-semibold" %>
            <%= f.text_field :tags, value: @paste.tags.join(", "), class: "mt-1 w-full border border-[var(--border)] px-3 py-2" %>
            <div class="text-xs text-[var(--muted)] mt-1">
                <p>Tags are optional and can be used to categorize your paste.</p>
                <p>Separate multiple tags with commas. E.g. "pokemon, faq, hgss, gen 4"</p>
            </div>
        </div>

        <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-2">
                <%= f.label :visibility, "Visibility", class: "text-sm font-semibold" %>
                <%= f.select :visibility, Paste.visibilities.keys.map { |k| [k, k] },
                {}, class: button_class(variant: :default, size: :sm) %>
            </div>

            <%= f.submit(@paste.persisted? ? "Save changes" : "Create paste", class: button_class(variant: :default, size: :sm)) %>
        </div>
    <% end %>
    </div>

    <details data-markdown-preview-target="details" class="w-full p-4 bg-[var(--surface)] border-y border-[var(--border)] hover:bg-[var(--surface2)] hidden">
        <summary class="cursor-pointer text-md text-[var(--text)]">Markdown preview</summary>
        <div data-markdown-preview-target="output" class="mt-3">
            <%= render "shared/markdown_viewer", content: @paste.body %>
        </div>
    </details>
</div>

