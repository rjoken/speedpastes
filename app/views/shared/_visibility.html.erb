<% visibility = local_assigns[:visibility] %>

<% if visibility == "open" %>
    <%= icon "globe-alt", variant: "solid", class: "w-4 h-4 text-[var(--muted)]", title: "Open" %>
<% elsif visibility == "unlisted" %>
    <%= icon "link", variant: "solid", class: "w-4 h-4 text-[var(--muted)]", title: "Unlisted" %>
<% else %>
    Visibility: <%= visibility.capitalize %>
<% end %> 