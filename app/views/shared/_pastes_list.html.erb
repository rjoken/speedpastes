<% pastes = local_assigns.fetch(:pastes, @pastes) %>
<% pagy_obj = local_assigns.fetch(:pagy, @pagy) %>
<% pin_context = local_assigns.fetch(:pin_context, false) %>
<% frame_id = local_assigns.fetch(:frame_id, "pastes_list") %>

<turbo-frame id="<%= frame_id %>">
    <div class="divide-y divide-[var(--border-muted)]">
        <% pastes.each do |paste| %>
        <div class="px-4 py-3">
            <div class="flex items-center justify-between gap-3">
                <div class="min-w-0">
                    <%= link_to short_paste_path(paste.shortcode), class: link_class(variant: :bold), data: { turbo: false } do %>
                        <%= paste.title %>
                    <% end %>
                    <% unless @user.present? %>
                        <span class="text-xs text-[var(--muted)] mt-1"> by <%= link_to paste.user.username, profile_path(paste.user.id), class: link_class(variant: :muted, size: :xs), data: { turbo: false } %></span>
                    <% end %>

                    <div class="text-xs text-[var(--muted)] mt-1 flex items-center gap-1">
                        <%= paste.created_at.strftime("%Y-%m-%d %H:%M") %>
                        <% if paste.user.show_view_count? || paste.user == current_user %>
                            <span>|</span> 
                            <div class="text-xs text-[var(--muted)] flex gap-1" title="Total views"><%= icon "eye", variant: "solid", options: {class: "w-4 h-4"}, width: 16, height: 16, aria: { hidden: true } %> <%= paste.views %></div>
                        <% end %>
                        <% if current_user == paste.user || current_user&.admin? %>
                            <span>|</span> 
                            <%= render "shared/visibility", visibility: paste.visibility %>
                            <span>|</span>
                            <%= link_to edit_paste_path(paste), class: link_class(variant: :muted, size: :xs), data: { turbo: false }, aria: { label: "Edit paste" }, title: "Edit paste" do %> 
                                <%= icon "pencil", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 16, height: 16, aria: { hidden: true } %>
                            <% end %>
                            <%= button_to paste_path(paste, context: (@user.present? ? "profile" : "pastes")), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this paste?", turbo_frame: "_top"}, form_class: "inline", class: link_class(variant: :muted, size: :xs), title: "Delete paste", aria: { label: "Delete paste" } do %>
                                <%= icon "trash", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 16, height: 16, aria: { hidden: true } %>
                            <% end %>
                            <% if @user.present? %>
                                <% pin = current_user.user_pins.find_by(paste_id: paste.id) %>
                                <% if pin.present? %>
                                    <%= button_to user_pin_path(id: pin.id, user_id: @user.id), method: :delete, data: { turbo_method: :delete, turbo_frame: "_top" }, class: link_class(variant: :muted, size: :xs), title: "Unpin paste", aria: { label: "Unpin paste" } do %>
                                        <%= icon "pin-slash", library: "sidekickicons", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 16, height: 16, aria: { hidden: true } %>
                                    <% end %>
                                    <% if pin_context %>
                                        <% can_move_up = current_user.user_pins.where("position < ?", pin.position).exists? %>
                                        <% can_move_down = current_user.user_pins.where("position > ?", pin.position).exists? %>
                                        <% if can_move_up %>
                                            <%= button_to user_pin_path(id: pin.id, user_id: @user.id, direction: "up"), method: :patch, data: { turbo_method: :patch, turbo_frame: "_top" }, class: link_class(variant: :muted, size: :lg), title: "Move pin up", aria: { label: "Move pin up" } do %>
                                                <%= icon "arrow-up", variant: "solid", class: link_class(variant: :muted, size: :lg), width: 16, height: 16, aria: { hidden: true } %>
                                            <% end %>
                                        <% end %>
                                        <% if can_move_down %>
                                            <%= button_to user_pin_path(id: pin.id, user_id: @user.id, direction: "down"), method: :patch, data: { turbo_method: :patch, turbo_frame: "_top" }, class: link_class(variant: :muted, size: :lg), title: "Move pin down", aria: { label: "Move pin down" } do %>
                                                <%= icon "arrow-down", variant: "solid", class: link_class(variant: :muted, size: :lg), width: 16, height: 16, aria: { hidden: true } %>
                                            <% end %>
                                        <% end %>
                                    <% end %>
                                <% else %>
                                    <%= button_to user_pins_path(paste_id: paste.id, user_id: @user.id), method: :post, data: { turbo_method: :post, turbo_frame: "_top" }, class: link_class(variant: :muted, size: :xs), title: "Pin paste", aria: { label: "Pin paste" } do %>
                                        <%= icon "pin", library: "sidekickicons", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 16, height: 16, aria: { hidden: true } %>
                                    <% end %>
                                <% end %>
                                <% if @user.is_supporter? %>
                                    <% if @user.userpage.nil? || @user.userpage.paste_id != paste.id %>
                                        <%= button_to userpages_path(user_id: @user.id, paste_id: paste.id), method: :post, data: { turbo_frame: "_top" }, class: link_class(variant: :muted, size: :xs), title: "Set userpage", aria: { label: "Set userpage" } do %>
                                            <%= icon "home", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 16, height: 16, aria: { hidden: true } %>
                                        <% end %>
                                    <% else %>
                                        <%= button_to  userpage_path(@user.userpage, user_id: @user.id), method: :delete, data: { turbo_frame: "_top" }, class: link_class(variant: :muted, size: :xs), title: "Remove userpage", aria: { label: "Remove userpage" } do %>
                                            <%= icon "home", variant: "outline", class: link_class(variant: :muted, size: :xs), width: 16, height: 16, aria: { hidden: true } %>
                                        <% end %>
                                    <% end %>
                                <% end %>
                            <% end %>
                        <% end %>
                    </div>
                    <% if paste.tags.any? %>
                        <div class="flex items-center gap-2 mt-2 flex-wrap">
                            <span class="text-xs text-[var(--muted)]">Tags:</span>
                            <% paste.tags.each do |tag| %>
                                <div class="text-xs text-[var(--muted)] bg-[var(--button-bg)] border border-[var(--border)] px-2 py-1 cursor-default"><%= tag %></div>
                            <% end %>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
        <% end %>

        <% if pastes.empty? %>
            <div class="text-sm text-[var(--muted)] px-4 py-6">
                <% if params[:q].present? %>
                    No pastes found matching "<%= params[:q] %>".
                <% else %>
                    <%= @user.present? ? "This user hides many secrets!" : "No public pastes found." %>
                <% end %>
            </div>
        <% end %>
    </div>

    <% if pagy_obj.present? %>
        <div class="border-t border-[var(--border-muted)] px-4 py-3 flex justify-center">
            <%= render "shared/pagy_nav", pagy: pagy_obj %>
        </div>
    <% end %>
</turbo-frame>