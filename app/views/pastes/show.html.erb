<% content_for :head do %>
  <meta property="og:title" content="<%= @paste.title %>">
  <meta property="og:description" content="<%= truncate(@paste.body, length: 200) %>">
  <meta property="og:type" content="article">
  <meta name="description" content="<%= truncate(@paste.body, length: 200) %>">
<% end %>

<div>
  <h1 class="font-bold text-4xl"><%= @paste.title %></h1>
  <div class="flex flex-wrap items-center gap-3 mt-2 mb-4">
    <div class="flex items-center gap-2">
      <%= render "shared/avatar", user: @paste.user, size: 24 %>
      <span><%= link_to @paste.user.username, profile_path(@paste.user.id), class: link_class(variant: :bold, size: :sm) %></span>
    </div>
    <span class="text-xs text-[var(--muted)]">|</span>
    <span class="text-xs text-[var(--muted)]" title="<%= @paste.created_at %> <%= @paste.edited_at.present? ? "(Edited: #{@paste.edited_at})" : "" %>"><%= time_ago_in_words(@paste.created_at) %> ago</span>
    <% if @paste.edited_at.present? %>
      <span class="text-xs text-[var(--muted)]"><%= " (Edited) " %></span>
    <% end %>
    <% if @paste.user.show_view_count? || @paste.user == current_user %>
      <span class="text-xs text-[var(--muted)]">|</span>
      <div class="text-xs text-[var(--muted)] flex gap-1" title="Total views"><%= icon "eye", variant: "solid", width: 16, height: 16, aria: { hidden: true } %> <%= @paste.views %></div>
    <% end %>
    <span class="text-xs text-[var(--muted)]">|</span>
    <div class="text-xs text-[var(--muted)] flex" title="Visibility: <%= @paste.visibility.capitalize %>">
    <%= render "shared/visibility", visibility: @paste.visibility %>
    </div>
      <% if current_user == @paste.user || current_user&.admin? %>
        <span class="text-xs text-[var(--muted)]">|</span>
        <div class="flex items-center gap-2">
          <%= link_to edit_paste_path(@paste), class: link_class(variant: :muted, size: :xs), aria: { label: "Edit paste" }, title: "Edit paste" do %>
            <%= icon "pencil", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 14, height: 14, aria: { hidden: true } %>
          <% end %>
          <%= button_to paste_path(@paste), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this paste?" }, form_class: "inline-flex", class: link_class(variant: :muted, size: :xs), title: "Delete paste", aria: { label: "Delete paste" } do %>
            <%= icon "trash", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 14, height: 14, aria: { hidden: true } %>
          <% end %>
        <% end %>
        <%= link_to raw_paste_path(@paste.shortcode), class: link_class(variant: :muted, size: :xs), target: "_blank", rel: "noopener", aria: { label: "View raw paste" }, title: "View raw paste" do %>
          <%= icon "document-text", variant: "solid", class: link_class(variant: :muted, size: :xs), width: 14, height: 14, aria: { hidden: true } %>
        <% end %>
      </div>
  </div>
  <% if @paste.tags.any? %>
    <div class="flex items-center gap-2 mb-4 flex-wrap">
      <span class="text-xs text-[var(--muted)]">Tags:</span>
      <% @paste.tags.each do |tag| %>
        <div class="text-xs text-[var(--muted)] bg-[var(--surface)] border border-[var(--border)] px-2 py-1 cursor-default"><%= tag %></div>
      <% end %>
    </div>
  <% end %>
  <div class="border border-[var(--border)] bg-[var(--surface)] shadow-sm">
  <% if @paste.plain? %>
    <%= render "shared/paste_viewer", content: @paste.body %>
  <% elsif @paste.markdown? %>
    <%= render "shared/markdown_viewer", content: @paste.body %>
  <% end %>
  </div>
</div>
